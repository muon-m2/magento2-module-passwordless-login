<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Confirm Sign In</title>
        <css src="Muon_PasswordlessLogin::css/passwordlesslogin.css"/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="passwordlesslogin.authenticate.confirm"
                   template="Muon_PasswordlessLogin::login/authenticate.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">
                        Muon\PasswordlessLogin\ViewModel\AuthenticateViewModel
                    </argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
