{
    "name": "muon/module-passwordless-login",
    "description": "Allows Magento 2 customers to authenticate via a one-time magic link sent to their registered email address, without requiring a password.",
    "version": "1.0.0",
    "license": [
        "proprietary"
    ],
    "type": "magento2-module",
    "require": {
        "php": "~8.3",
        "magento/framework": "^103.0",
        "magento/module-customer": "^103.0",
        "magento/module-store": "^101.0",
        "magento/module-config": "^101.0",
        "magento/module-cron": "^101.0",
        "magento/module-email": "^101.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Muon\\PasswordlessLogin\\": ""
        }
    }
}
