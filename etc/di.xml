<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Muon\PasswordlessLogin\Api\MagicLinkServiceInterface"
                type="Muon\PasswordlessLogin\Model\MagicLinkService"/>
    <preference for="Muon\PasswordlessLogin\Api\TokenRepositoryInterface"
                type="Muon\PasswordlessLogin\Model\TokenRepository"/>
    <preference for="Muon\PasswordlessLogin\Api\Data\TokenInterface"
                type="Muon\PasswordlessLogin\Model\Token"/>

    <!-- Use the session proxy to avoid premature session initialisation in the constructor -->
    <type name="Muon\PasswordlessLogin\Controller\Login\Authenticate">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>
    <type name="Muon\PasswordlessLogin\Controller\Login\AuthenticatePost">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>
</config>
