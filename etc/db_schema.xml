<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="muon_passwordless_login_token" resource="default" engine="innodb"
           comment="Muon PasswordlessLogin - Magic Link Tokens">
        <column xsi:type="int" name="token_id" padding="10" unsigned="true" nullable="false"
                identity="true" comment="Token ID"/>
        <column xsi:type="int" name="customer_id" padding="10" unsigned="true" nullable="false"
                comment="Customer ID"/>
        <column xsi:type="varchar" name="token" nullable="false" length="64"
                comment="SHA-256 hashed token"/>
        <column xsi:type="datetime" name="expires_at" nullable="false"
                comment="Token expiry datetime"/>
        <column xsi:type="datetime" name="used_at" nullable="true"
                comment="Datetime when the token was consumed; NULL means unused"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Token creation datetime"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="token_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="MUON_PASSWORDLESS_LOGIN_TOKEN_TOKEN">
            <column name="token"/>
        </constraint>

        <!-- Used by rate-limit query: WHERE customer_id = ? AND created_at >= ? -->
        <index referenceId="MUON_PASSWORDLESS_LOGIN_TOKEN_CUSTOMER_ID_CREATED_AT" indexType="btree">
            <column name="customer_id"/>
            <column name="created_at"/>
        </index>
        <!-- Used by the cleanup cron: WHERE expires_at < NOW() -->
        <index referenceId="MUON_PASSWORDLESS_LOGIN_TOKEN_EXPIRES_AT" indexType="btree">
            <column name="expires_at"/>
        </index>
    </table>
</schema>
