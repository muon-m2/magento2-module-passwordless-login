<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="muon" translate="label" sortOrder="500">
            <label>Muon</label>
        </tab>
        <section id="muon_passwordlesslogin" translate="label" sortOrder="100"
            showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Passwordless Login</label>
            <tab>muon</tab>
            <resource>Muon_PasswordlessLogin::config</resource>
            <group id="general" translate="label" sortOrder="10"
                showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                    showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Passwordless Login</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="token_lifetime" translate="label comment" type="text" sortOrder="20"
                    showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Token Lifetime (minutes)</label>
                    <comment>How long the magic link remains valid. Default: 15 minutes.</comment>
                    <validate>required-entry validate-greater-than-zero validate-digits</validate>
                </field>
                <field id="max_attempts" translate="label comment" type="text" sortOrder="30"
                    showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Requests Per Hour</label>
                    <comment>Maximum magic link requests allowed per email per hour. Default: 5.</comment>
                    <validate>required-entry validate-greater-than-zero validate-digits</validate>
                </field>
            </group>
        </section>
    </system>
</config>
